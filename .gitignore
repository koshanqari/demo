# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---------- dependencies ----------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---------- testing & coverage ----------
/coverage
*.lcov

# ---------- next.js build output ----------
/.next/
/out/
/build
/dist
*.tsbuildinfo
next-env.d.ts

# ---------- vercel ----------
.vercel

# ---------- env (never commit secrets) ----------
.env
.env.*
.env.*.local
# Keep the template
!.env.example

# ---------- logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------- OS junk ----------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------- editors / IDE ----------
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# ---------- misc ----------
*.pem
*.key
*.crt
.cache/
.turbo/
tmp/
.temp/

# ---------- local agent / tool state ----------
.claude/
.cursor/
